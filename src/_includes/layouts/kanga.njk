{% extends 'layouts/base.njk' %}
{% from 'components/title.njk' import title as pagetitle %}
{% from 'components/breadcrumbs.njk' import breadcrumbs as breadcrumbsList %}
{% from 'components/subNavigation.njk' import subNavigation as subNavigation %}

{% block beforeContent %}{% endblock %}

{% block content %}
<div class="grid">
  <div class="grid-column--x4">
    {{ subNavigation({
      items: collections.kanga,
      id: 'KangaMenu',
      title: 'Kanga menu',
      root: '/kanga/'
    }) }}
  </div>
  <div class="grid-column--x8">
    {% if showBreadcrumbs %}
      {{ breadcrumbsList({
        classes: 'space--margin-bottom-s',
        items: [
          {
            title: 'Kanga',
            url: '/kanga/'
          },
          {
            title: kangaSection | title
          }
        ]
      }) }}
    {% endif %}

    {{ pagetitle({
      classes: 'space--margin-bottom-l',
      text: title,
      caption: caption if caption
    }) if title }}

    {% if introduction %}
      <div class="prose prose--flow space--margin-bottom-l">
        <p class="type-scale-1">{{ introduction }}</p>
      </div>
    {% endif %}

    {% if isShortcode %}
      <div class="callout prose space--margin-bottom-m">
        <p>{{ title }} is a shortcode. It does not require a Nunjucks <code>import</code> statement.</p>
      </div>
    {% endif %}

    <div class="prose prose--flow">
      {{ content | safe }}
    </div>
  </div>
</div>
{% endblock %}
